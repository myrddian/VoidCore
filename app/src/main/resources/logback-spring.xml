<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!--
    Two profiles: default uses a human-readable pattern (handy for local
    dev), prod uses JSON to stdout so the docker json-file driver and any
    downstream log aggregator (Loki/journald) get structured records.
  -->
  <springProfile name="!prod">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
  </springProfile>

  <springProfile name="prod">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>
  </springProfile>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
