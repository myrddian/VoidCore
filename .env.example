# Network
HTTP_BIND_ADDR=127.0.0.1
HTTP_PORT=8080
DOOR_BIND_ADDR=127.0.0.1
DOOR_PORT=8081
PUBLIC_URL=https://bbs.example.com

# Postgres
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=CHANGEME
PG_DB_NAME=voidcore
PG_APP_USER=voidcore_app
PG_APP_PASSWORD=CHANGEME

# Sysop bootstrap account
SYSOP_HANDLE=sysop
SYSOP_INITIAL_PASSWORD=CHANGEME

# Session lifetime (days)
SESSION_TTL_DAYS=30

# Argon2id tuning
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
