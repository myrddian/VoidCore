# Optional local override file for docker compose.
# You do not need this file for a first local boot; the compose stack has
# documented repo defaults. Copy this to `.env` only when you want to override
# ports, DB credentials, sysop bootstrap, or Flyway locations.

# Network
HTTP_BIND_ADDR=127.0.0.1
HTTP_PORT=8080
DOOR_BIND_ADDR=127.0.0.1
DOOR_PORT=8081
PUBLIC_URL=http://localhost:8080
CITYLINE_DOOR_URL=ws://app:8081/ws/door
CITYLINE_DEBUG_PROMPTS=0

# Postgres
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=voidcore-local-postgres-superuser-only-for-compose
PG_DB_NAME=voidcore
PG_APP_USER=voidcore_app
PG_APP_PASSWORD=voidcore-local-app-db-password-only-for-compose

# Optional sysop bootstrap account
# Leave these blank to start the stack without a pre-seeded sysop. Set both if
# you want first boot to create/promote an admin user.
SYSOP_HANDLE=
SYSOP_INITIAL_PASSWORD=

# Session lifetime (days)
SESSION_TTL_DAYS=30

# Optional overlay / instance migration hook
# Example:
# VOIDCORE_FLYWAY_LOCATIONS=classpath:db/migration,filesystem:/instance/migrations
# Use this only when your deploy adds a mounted overlay migration directory.
# VOIDCORE_FLYWAY_LOCATIONS=classpath:db/migration

# Argon2id tuning
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
